#! /usr/bin/vvp
:ivl_version "12.0 (stable)";
:ivl_delay_selection "TYPICAL";
:vpi_time_precision - 12;
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/system.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/vhdl_sys.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/vhdl_textio.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/v2005_math.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/va_math.vpi";
S_0x61f4cb8fe4f0 .scope module, "tb" "tb" 2 2;
 .timescale -9 -12;
v0x61f4cb9474b0_0 .var "a", 0 0;
v0x61f4cb947580_0 .var "b", 0 0;
v0x61f4cb947650_0 .net "y", 0 0, L_0x61f4cb947750;  1 drivers
S_0x61f4cb8fe680 .scope module, "dut" "and2" 2 6, 3 3 0, S_0x61f4cb8fe4f0;
 .timescale -9 -12;
    .port_info 0 /OUTPUT 1 "y";
    .port_info 1 /INPUT 1 "a";
    .port_info 2 /INPUT 1 "b";
L_0x61f4cb947750 .functor AND 1, v0x61f4cb9474b0_0, v0x61f4cb947580_0, C4<1>, C4<1>;
v0x61f4cb8fe8b0_0 .net "a", 0 0, v0x61f4cb9474b0_0;  1 drivers
v0x61f4cb9472d0_0 .net "b", 0 0, v0x61f4cb947580_0;  1 drivers
v0x61f4cb947390_0 .net "y", 0 0, L_0x61f4cb947750;  alias, 1 drivers
    .scope S_0x61f4cb8fe4f0;
T_0 ;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x61f4cb9474b0_0, 0, 1;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x61f4cb947580_0, 0, 1;
    %vpi_call 2 12 "$dumpfile", "sim.vcd" {0 0 0};
    %vpi_call 2 13 "$dumpvars", 32'sb00000000000000000000000000000000, S_0x61f4cb8fe4f0 {0 0 0};
    %delay 10000, 0;
    %pushi/vec4 1, 1, 1;
    %force/vec4 v0x61f4cb8fe8b0_0;
    %delay 10000, 0;
    %vpi_call 2 19 "$finish" {0 0 0};
    %end;
    .thread T_0;
# The file index is used to find the file name in the following table.
:file_names 4;
    "N/A";
    "<interactive>";
    "tb.v";
    "netlist.v";
