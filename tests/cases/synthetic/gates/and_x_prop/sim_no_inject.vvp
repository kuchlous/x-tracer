#! /usr/bin/vvp
:ivl_version "12.0 (stable)";
:ivl_delay_selection "TYPICAL";
:vpi_time_precision - 12;
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/system.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/vhdl_sys.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/vhdl_textio.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/v2005_math.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/va_math.vpi";
S_0x61d0230cec60 .scope module, "tb" "tb" 2 2;
 .timescale -9 -12;
v0x61d0230de1e0_0 .var "a", 0 0;
v0x61d0230de2b0_0 .var "b", 0 0;
v0x61d0230de380_0 .net "y", 0 0, L_0x61d0230de480;  1 drivers
S_0x61d0230cedf0 .scope module, "dut" "and2" 2 6, 3 3 0, S_0x61d0230cec60;
 .timescale -9 -12;
    .port_info 0 /OUTPUT 1 "y";
    .port_info 1 /INPUT 1 "a";
    .port_info 2 /INPUT 1 "b";
L_0x61d0230de480 .functor AND 1, v0x61d0230de1e0_0, v0x61d0230de2b0_0, C4<1>, C4<1>;
v0x61d0230cf020_0 .net "a", 0 0, v0x61d0230de1e0_0;  1 drivers
v0x61d0230de000_0 .net "b", 0 0, v0x61d0230de2b0_0;  1 drivers
v0x61d0230de0c0_0 .net "y", 0 0, L_0x61d0230de480;  alias, 1 drivers
    .scope S_0x61d0230cec60;
T_0 ;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x61d0230de1e0_0, 0, 1;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x61d0230de2b0_0, 0, 1;
    %vpi_call 2 11 "$dumpfile", "sim_no_inject.vcd" {0 0 0};
    %vpi_call 2 12 "$dumpvars", 32'sb00000000000000000000000000000000, S_0x61d0230cec60 {0 0 0};
    %delay 20000, 0;
    %vpi_call 2 15 "$finish" {0 0 0};
    %end;
    .thread T_0;
# The file index is used to find the file name in the following table.
:file_names 4;
    "N/A";
    "<interactive>";
    "tb_no_inject.v";
    "netlist.v";
